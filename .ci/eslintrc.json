{
  "root": true,
  "env": { "browser": true, "serviceworker": true, "es2023": true },
  "parserOptions": { "ecmaVersion": 2023, "sourceType": "script" },
  "globals": { "ethers": "readonly" },
  "rules": {
    "no-undef": "error",
    "no-dupe-keys": "error",
    "no-dupe-args": "error",
    "no-const-assign": "error",
    "no-redeclare": "error"
  }
}
